{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git merge-base:*)",
      "Bash(git ls-tree:*)",
      "Bash(git ls-files:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push)",
      "Bash(git push origin:*)",
      "Bash(git push -u origin:*)",
      "Bash(git push --set-upstream origin:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git worktree add:*)",
      "Bash(git worktree list:*)",
      "Bash(git worktree prune:*)",
      "Bash(git worktree remove:*)",
      "Bash(git branch -d:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh repo view:*)",
      "Bash(gh api:*)",
      "Write",
      "Edit",
      "Read"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin --force:*)",
      "Bash(git push origin -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(gh pr merge:*)",
      "Bash(sudo:*)"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git push -u origin main)",
      "Bash(git push -u origin main:*)",
      "Bash(git push --set-upstream origin main)",
      "Bash(git push --set-upstream origin main:*)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin HEAD:main:*)",
      "Bash(git push origin HEAD:refs/heads/main)",
      "Bash(git push origin HEAD:refs/heads/main:*)",
      "Bash(git push origin refs/heads/main)",
      "Bash(git push origin refs/heads/main:*)",
      "Bash(git push origin +main:*)",
      "Bash(git push origin +HEAD:main:*)",
      "Bash(git push origin +HEAD:refs/heads/main:*)",
      "Bash(git push origin :main)",
      "Bash(git push origin :refs/heads/main)",
      "Read(**/.env)",
      "Edit(**/.env)",
      "Write(**/.env)",
      "Read(secrets/**)",
      "Edit(secrets/**)",
      "Write(secrets/**)",
      "Read(**/*.pem)",
      "Edit(**/*.pem)",
      "Write(**/*.pem)",
      "Read(**/*.key)",
      "Edit(**/*.key)",
      "Write(**/*.key)",
      "Read(**/id_rsa*)",
      "Edit(**/id_rsa*)",
      "Write(**/id_rsa*)",
      "Read(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "Write(**/.ssh/**)",
      "Read(**/.aws/credentials*)",
      "Edit(**/.aws/credentials*)",
      "Write(**/.aws/credentials*)",
      "Read(**/*.p12)",
      "Edit(**/*.p12)",
      "Write(**/*.p12)",
      "Read(**/*.mobileprovision)",
      "Edit(**/*.mobileprovision)",
      "Write(**/*.mobileprovision)",
      "Read(**/GoogleService-Info.plist)",
      "Edit(**/GoogleService-Info.plist)",
      "Write(**/GoogleService-Info.plist)",
      "Bash(cat **/.env*)",
      "Bash(cat **/secrets/**)",
      "Bash(cat **/*.p12)",
      "Bash(cat **/*.mobileprovision)"
    ]
  }
}
